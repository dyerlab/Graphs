{"kind":"symbol","identifier":{"url":"doc:\/\/Graphs\/documentation\/Graphs\/applyManyBodyForce(to:strength:minDistance:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyManyBodyForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"state","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV","text":"SimulationState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sf","text":"Float","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"minDistance","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sf","text":"Float","kind":"typeIdentifier"},{"text":" = 1.0)","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"state","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The simulation state to modify. Velocities are updated in place."}]}]},{"name":"strength","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The force strength. Negative values cause repulsion (typical),"},{"type":"text","text":" "},{"type":"text","text":"positive values cause attraction. Default is set via "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationConfig"},{"type":"text","text":"."}]}]},{"name":"minDistance","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Minimum distance for force calculations. Prevents extremely"},{"type":"text","text":" "},{"type":"text","text":"large forces when nodes are very close. Defaults to 1.0."}]}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"This force causes nodes to repel (with negative strength) or attract (with"},{"type":"text","text":" "},{"type":"text","text":"positive strength) each other. It’s the primary force that spreads nodes apart"},{"type":"text","text":" "},{"type":"text","text":"in a force-directed layout."}],"type":"paragraph"},{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"inlineContent":[{"type":"text","text":"The force follows an inverse-square law similar to gravity or electrostatic"},{"type":"text","text":" "},{"type":"text","text":"force. The magnitude scales with the simulation’s alpha value, causing the"},{"type":"text","text":" "},{"type":"text","text":"force to decrease as the simulation settles."}],"type":"paragraph"},{"text":"Complexity","type":"heading","anchor":"Complexity","level":2},{"inlineContent":[{"type":"text","text":"O(N²) where N is the number of nodes. This implementation is optimized for"},{"type":"text","text":" "},{"type":"text","text":"small graphs (< 500 nodes) with a simple memory access pattern."}],"type":"paragraph"},{"text":"Coincident Nodes","type":"heading","anchor":"Coincident-Nodes","level":2},{"inlineContent":[{"type":"text","text":"When two nodes occupy the same position, a small random offset (“jiggle”)"},{"type":"text","text":" "},{"type":"text","text":"is applied to break the symmetry and allow the nodes to separate."}],"type":"paragraph"},{"text":"Example","type":"heading","anchor":"Example","level":2},{"syntax":"swift","type":"codeListing","code":["applyManyBodyForce(to: &state, strength: -30.0)"]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyManyBodyForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Float","preciseIdentifier":"s:Sf"},{"kind":"text","text":", "},{"kind":"externalParam","text":"minDistance"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"},{"text":")","kind":"text"}],"roleHeading":"Function","modules":[{"name":"Graphs"}],"title":"applyManyBodyForce(to:strength:minDistance:)","role":"symbol","symbolKind":"func","externalID":"s:6Graphs18applyManyBodyForce2to8strength11minDistanceyAA15SimulationStateVz_S2ftF"},"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"abstract":[{"text":"Applies a many-body force between all pairs of nodes.","type":"text"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/graphs\/applymanybodyforce(to:strength:mindistance:)"]}],"references":{"doc://Graphs/documentation/Graphs":{"title":"Graphs","url":"\/documentation\/graphs","identifier":"doc:\/\/Graphs\/documentation\/Graphs","abstract":[],"type":"topic","kind":"symbol","role":"collection"},"doc://Graphs/documentation/Graphs/SimulationConfig":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationConfig","title":"SimulationConfig","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationConfig","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"SimulationConfig","kind":"identifier"}],"url":"\/documentation\/graphs\/simulationconfig","abstract":[{"type":"text","text":"Configuration parameters for the force-directed graph simulation."}]},"doc://Graphs/documentation/Graphs/applyManyBodyForce(to:strength:minDistance:)":{"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ",