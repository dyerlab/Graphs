{"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/graphs\/applymanybodyforce(to:strength:mindistance:)"]}],"identifier":{"url":"doc:\/\/Graphs\/documentation\/Graphs\/applyManyBodyForce(to:strength:minDistance:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"Applies a many-body force between all pairs of nodes."}],"metadata":{"roleHeading":"Function","externalID":"s:6Graphs18applyManyBodyForce2to8strength11minDistanceyAA15SimulationStateVz_S2ftF","role":"symbol","symbolKind":"func","title":"applyManyBodyForce(to:strength:minDistance:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyManyBodyForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:6Graphs15SimulationStateV","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":", "},{"kind":"externalParam","text":"minDistance"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":")"}],"modules":[{"name":"Graphs"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyManyBodyForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"state","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:6Graphs15SimulationStateV","text":"SimulationState","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"minDistance","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":" = 1.0)","kind":"text"}],"platforms":["macOS"]}]},{"parameters":[{"name":"state","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The simulation state to modify. Velocities are updated in place."}]}]},{"name":"strength","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The force strength. Negative values cause repulsion (typical),"},{"type":"text","text":" "},{"type":"text","text":"positive values cause attraction. Default is set via "},{"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationConfig","isActive":true,"type":"reference"},{"type":"text","text":"."}]}]},{"name":"minDistance","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Minimum distance for force calculations. Prevents extremely"},{"type":"text","text":" "},{"type":"text","text":"large forces when nodes are very close. Defaults to 1.0."}]}]}],"kind":"parameters"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This force causes nodes to repel (with negative strength) or attract (with","type":"text"},{"text":" ","type":"text"},{"text":"positive strength) each other. It’s the primary force that spreads nodes apart","type":"text"},{"text":" ","type":"text"},{"text":"in a force-directed layout.","type":"text"}]},{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The force follows an inverse-square law similar to gravity or electrostatic"},{"type":"text","text":" "},{"text":"force. The magnitude scales with the simulation’s alpha value, causing the","type":"text"},{"text":" ","type":"text"},{"text":"force to decrease as the simulation settles.","type":"text"}]},{"text":"Complexity","anchor":"Complexity","type":"heading","level":2},{"inlineContent":[{"text":"O(N²) where N is the number of nodes. This implementation is optimized for","type":"text"},{"text":" ","type":"text"},{"text":"small graphs (< 500 nodes) with a simple memory access pattern.","type":"text"}],"type":"paragraph"},{"text":"Coincident Nodes","anchor":"Coincident-Nodes","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"When two nodes occupy the same position, a small random offset (“jiggle”)"},{"type":"text","text":" "},{"type":"text","text":"is applied to break the symmetry and allow the nodes to separate."}],"type":"paragraph"},{"text":"Example","anchor":"Example","type":"heading","level":2},{"code":["applyManyBodyForce(to: &state, strength: -30.0)"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"references":{"doc://Graphs/documentation/Graphs":{"role":"collection","title":"Graphs","url":"\/documentation\/graphs","identifier":"doc:\/\/Graphs\/documentation\/Graphs","kind":"symbol","type":"topic","abstract":[]},"doc://Graphs/documentation/Graphs/SimulationConfig":{"role":"symbol","url":"\/documentation\/graphs\/simulationconfig","abstract":[{"type":"text","text":"Configuration parameters for the force-directed graph simulation."}],"kind":"symbol","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationConfig","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationConfig","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"SimulationConfig"}],"title":"SimulationConfig","type":"topic"},"doc://Graphs/documentation/Graphs/SimulationState":{"role":"symbol","title":"SimulationState","url":"\/documentation\/graphs\/simulationstate","identifier"