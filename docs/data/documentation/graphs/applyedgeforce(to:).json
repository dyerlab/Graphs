{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/Graphs\/documentation\/Graphs\/applyEdgeForce(to:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"kind":"symbol","metadata":{"modules":[{"name":"Graphs"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyEdgeForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","kind":"typeIdentifier","preciseIdentifier":"s:6Graphs15SimulationStateV"},{"text":")","kind":"text"}],"externalID":"s:6Graphs14applyEdgeForce2toyAA15SimulationStateVz_tF","symbolKind":"func","roleHeading":"Function","title":"applyEdgeForce(to:)","role":"symbol"},"abstract":[{"text":"Applies spring forces along edges to pull connected nodes together.","type":"text"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyEdgeForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":" "},{"kind":"internalParam","text":"state"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier","text":"SimulationState"},{"kind":"text","text":")"}]}]},{"kind":"parameters","parameters":[{"name":"state","content":[{"type":"paragraph","inlineContent":[{"text":"The simulation state to modify. Velocities are updated in place.","type":"text"}]}]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Each edge acts as a spring with a rest length ("},{"type":"reference","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/distance","isActive":true},{"type":"text","text":") and strength"},{"type":"text","text":" "},{"type":"text","text":"("},{"isActive":true,"type":"reference","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/weight"},{"type":"text","text":"). Nodes closer than the rest length are pushed apart; nodes"},{"type":"text","text":" "},{"type":"text","text":"farther than the rest length are pulled together."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The edge force is essential for creating structure in the graph. Without it,","type":"text"},{"text":" ","type":"text"},{"text":"the many-body repulsion would push all nodes apart indefinitely. The edge","type":"text"},{"text":" ","type":"text"},{"text":"springs counteract this repulsion for connected nodes.","type":"text"}]},{"type":"heading","level":2,"anchor":"Physics-Model","text":"Physics Model"},{"type":"paragraph","inlineContent":[{"text":"The force uses Hooke’s law (F = -kx) where:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"k is the spring constant (","type":"text"},{"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/weight","isActive":true,"type":"reference"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"x is the displacement from rest length (current distance - "},{"type":"reference","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/distance","isActive":true},{"type":"text","text":")"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The force is scaled by the simulation’s alpha value.","type":"text"}]},{"type":"heading","level":2,"anchor":"Complexity","text":"Complexity"},{"type":"paragraph","inlineContent":[{"type":"text","text":"O(E) where E is the number of edges."}]},{"type":"heading","level":2,"anchor":"Example","text":"Example"},{"type":"codeListing","syntax":"swift","code":["applyEdgeForce(to: &state)"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/graphs\/applyedgeforce(to:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://Graphs/documentation/Graphs":{"role":"collection","abstract":[],"url":"\/documentation\/graphs","kind":"symbol","type":"topic","title":"Graphs","identifier":"doc:\/\/Graphs\/documentation\/Graphs"},"doc://Graphs/documentation/Graphs/Edge/distance":{"kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The target distance between connected nodes in simulation units."}],"title":"distance","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/distance","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"distance","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sf","text":"Float","kind":"typeIdentifier"}],"type":"topic","url":"\/documentation\/graphs\/edge\/distance"},"doc://Graphs/documentation/Graphs/SimulationState":{"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"text":"SimulationState","kind":"identifier"}],"title":"SimulationState","url":"\/documentation\/graphs\/simulationstate","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","kind":"identifier"}],"abstract":[{"text":"The mutable state of a force-directed graph simulation.","type":"text"}],"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState"},"doc://Graphs/documentation/Graphs/Edge/weight":{"url":"\/documentation\/graphs\/edge\/weight","kind":"symbol","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/weight","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"weight","kind":"identifier"},{"kind":"text","text":": "},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"}],"title":"weight","abstract":[{"type":"text","text":"The spring strength of t