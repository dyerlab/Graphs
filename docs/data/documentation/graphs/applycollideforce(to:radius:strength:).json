{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/graphs\/applycollideforce(to:radius:strength:)"]}],"abstract":[{"type":"text","text":"Applies a collision force to prevent node overlap."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyCollideForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"state","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","kind":"typeIdentifier","preciseIdentifier":"s:6Graphs15SimulationStateV","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState"},{"text":", ","kind":"text"},{"text":"radius","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":", "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Float","preciseIdentifier":"s:Sf"},{"kind":"text","text":" = 0.7)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The simulation state to modify. Velocities are updated in place.","type":"text"}]}],"name":"state"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The collision radius for each node. Nodes within 2× this distance"},{"type":"text","text":" "},{"type":"text","text":"are considered overlapping."}]}],"name":"radius"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"How strongly to push overlapping nodes apart. A value of 1.0"},{"type":"text","text":" "},{"type":"text","text":"fully resolves overlaps; smaller values allow some overlap. Defaults to 0.7."}]}],"name":"strength"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"This force detects when nodes are closer than a specified radius and pushes"},{"type":"text","text":" "},{"type":"text","text":"them apart. Unlike the many-body force, it only acts on very close nodes,"},{"type":"text","text":" "},{"type":"text","text":"making it suitable for preventing visual overlap."}],"type":"paragraph"},{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"The collision force helps keep the visualization readable by ensuring nodes"},{"type":"text","text":" "},{"type":"text","text":"don’t overlap. It’s particularly useful when nodes have varying sizes or"},{"type":"text","text":" "},{"type":"text","text":"when the many-body repulsion alone isn’t sufficient to prevent overlap."}],"type":"paragraph"},{"anchor":"Behavior","type":"heading","text":"Behavior","level":2},{"inlineContent":[{"type":"text","text":"When two nodes are within twice the collision radius (i.e., their “circles”"},{"text":" ","type":"text"},{"text":"overlap), a separating force is applied. The force is proportional to the","type":"text"},{"text":" ","type":"text"},{"text":"overlap amount.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Complexity","anchor":"Complexity","type":"heading"},{"inlineContent":[{"type":"text","text":"O(N²) where N is the number of nodes. For better performance with many nodes,"},{"type":"text","text":" "},{"type":"text","text":"consider using a spatial data structure (not implemented in this version)."}],"type":"paragraph"},{"level":2,"text":"Example","anchor":"Example","type":"heading"},{"code":["\/\/ Default collision detection","applyCollideForce(to: &state, radius: 5.0)","","\/\/ Stronger collision response","applyCollideForce(to: &state, radius: 10.0, strength: 1.0)"],"type":"codeListing","syntax":"swift"}]}],"identifier":{"url":"doc:\/\/Graphs\/documentation\/Graphs\/applyCollideForce(to:radius:strength:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"externalID":"s:6Graphs17applyCollideForce2to6radius8strengthyAA15SimulationStateVz_S2ftF","role":"symbol","symbolKind":"func","modules":[{"name":"Graphs"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyCollideForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"radius","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"applyCollideForce(to:radius:strength:)","roleHeading":"Function"},"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"references":{"doc://Graphs/documentation/Graphs/SimulationState":{"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"text":"SimulationState","kind":"identifier"}],"title":"SimulationState","url":"\/documentation\/graphs\/simulationstate","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","kind":"identifier"}],"abstract":[{"text":"The mutable state of a force-directed graph simulation.","type":"text"}],"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState"},"doc://Graphs/documentation/Graphs":{"role":"collection","abstract":[],"url":"\/documentation\/graphs","kind":"symbol","type":"topic","title":"Graphs","identifier":"doc:\/\/Graphs\/documentation\/Graphs"},"doc://Graphs/documentation/Graphs/applyCollideForce(to:radius:strength:)":{"url":"\/documentation\/graphs