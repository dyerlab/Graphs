{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Graphs\/documentation\/Graphs\/applyCollideForce(to:radius:strength:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyCollideForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":" "},{"kind":"internalParam","text":"state"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"radius"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"},{"kind":"text","text":", "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"},{"kind":"text","text":" = 0.7)"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The simulation state to modify. Velocities are updated in place."}]}],"name":"state"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The collision radius for each node. Nodes within 2× this distance"},{"type":"text","text":" "},{"type":"text","text":"are considered overlapping."}]}],"name":"radius"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"How strongly to push overlapping nodes apart. A value of 1.0"},{"type":"text","text":" "},{"type":"text","text":"fully resolves overlaps; smaller values allow some overlap. Defaults to 0.7."}]}],"name":"strength"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This force detects when nodes are closer than a specified radius and pushes"},{"type":"text","text":" "},{"type":"text","text":"them apart. Unlike the many-body force, it only acts on very close nodes,"},{"type":"text","text":" "},{"type":"text","text":"making it suitable for preventing visual overlap."}],"type":"paragraph"},{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The collision force helps keep the visualization readable by ensuring nodes"},{"type":"text","text":" "},{"type":"text","text":"don’t overlap. It’s particularly useful when nodes have varying sizes or"},{"type":"text","text":" "},{"type":"text","text":"when the many-body repulsion alone isn’t sufficient to prevent overlap."}],"type":"paragraph"},{"text":"Behavior","anchor":"Behavior","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"When two nodes are within twice the collision radius (i.e., their “circles”"},{"type":"text","text":" "},{"type":"text","text":"overlap), a separating force is applied. The force is proportional to the"},{"type":"text","text":" "},{"type":"text","text":"overlap amount."}],"type":"paragraph"},{"text":"Complexity","anchor":"Complexity","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"O(N²) where N is the number of nodes. For better performance with many nodes,"},{"type":"text","text":" "},{"type":"text","text":"consider using a spatial data structure (not implemented in this version)."}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":2,"type":"heading"},{"syntax":"swift","code":["\/\/ Default collision detection","applyCollideForce(to: &state, radius: 5.0)","","\/\/ Stronger collision response","applyCollideForce(to: &state, radius: 10.0, strength: 1.0)"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyCollideForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"radius"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"},{"kind":"text","text":", "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"},{"kind":"text","text":")"}],"roleHeading":"Function","modules":[{"name":"Graphs"}],"title":"applyCollideForce(to:radius:strength:)","role":"symbol","symbolKind":"func","externalID":"s:6Graphs17applyCollideForce2to6radius8strengthyAA15SimulationStateVz_S2ftF"},"abstract":[{"text":"Applies a collision force to prevent node overlap.","type":"text"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/graphs\/applycollideforce(to:radius:strength:)"]}],"references":{"doc://Graphs/documentation/Graphs":{"title":"Graphs","url":"\/documentation\/graphs","identifier":"doc:\/\/Graphs\/documentation\/Graphs","abstract":[],"type":"topic","kind":"symbol","role":"collection"},"doc://Graphs/documentation/Graphs/SimulationState":{"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","navigatorTitle":[{"kind":"identifier","text":"SimulationState"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SimulationState"}],"type":"topic","kind":"symbol","role":"symbol","title":"SimulationState","url":"\/documentation\/graphs\/simulationstate","abstract":[{"text":"The mutable state of a force-directed graph simulation.","type":"text"}]},"doc://Graphs/documentation/Graphs/applyCollideForce(to:radius:strength:)":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/applyCollideForce(to:radius:strength:)","title":"applyCollideForce(to:radius:strength:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyCollideForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:6Graphs15SimulationStateV","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"radius"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":", "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":")"}],"type":"topic","abstract":[{"text":"Applies a collision force to prevent node overlap.","type":"text"}],"url":"\/documentation\/graphs\/applycollideforce(to:radius:strength:)"}}}