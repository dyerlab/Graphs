{"abstract":[{"type":"text","text":"Applies a centering force that pulls the graph’s centroid toward a target point."}],"kind":"symbol","identifier":{"url":"doc:\/\/Graphs\/documentation\/Graphs\/applyCenterForce(to:center:strength:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyCenterForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"state","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","kind":"typeIdentifier","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV"},{"text":", ","kind":"text"},{"text":"center","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SIMD2","kind":"typeIdentifier","preciseIdentifier":"s:s5SIMD2V"},{"text":"<","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"},{"text":"> = .zero, ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"},{"text":" = 0.1)","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"state","content":[{"inlineContent":[{"type":"text","text":"The simulation state to modify. Velocities are updated in place."}],"type":"paragraph"}]},{"name":"center","content":[{"inlineContent":[{"type":"text","text":"The target center point. Defaults to the origin (0, 0)."}],"type":"paragraph"}]},{"name":"strength","content":[{"inlineContent":[{"type":"text","text":"How strongly to pull toward the center. Higher values cause"},{"type":"text","text":" "},{"type":"text","text":"faster centering but may cause oscillation. Defaults to 0.1."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This force prevents the graph from drifting away from the visible area by","type":"text"},{"text":" ","type":"text"},{"text":"gently nudging all nodes so their centroid moves toward the center.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"The center force computes the centroid (average position) of all nodes and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"applies a velocity adjustment to move that centroid toward the target center."},{"type":"text","text":" "},{"type":"text","text":"This keeps the graph roughly centered in the view."}],"type":"paragraph"},{"anchor":"Behavior","type":"heading","text":"Behavior","level":2},{"type":"paragraph","inlineContent":[{"text":"Unlike other forces that operate on individual nodes, the center force operates","type":"text"},{"text":" ","type":"text"},{"text":"on the graph as a whole. It doesn’t change the relative positions of nodes;","type":"text"},{"text":" ","type":"text"},{"text":"it only translates the entire graph.","type":"text"}]},{"anchor":"Complexity","type":"heading","text":"Complexity","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"O(N) where N is the number of nodes."}]},{"anchor":"Example","type":"heading","text":"Example","level":2},{"syntax":"swift","type":"codeListing","code":["\/\/ Center at origin with default strength","applyCenterForce(to: &state)","","\/\/ Center at a specific point","applyCenterForce(to: &state, center: SIMD2(100, 100))","","\/\/ Stronger centering","applyCenterForce(to: &state, strength: 0.3)"]}]}],"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"sections":[],"metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyCenterForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"center","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SIMD2","preciseIdentifier":"s:s5SIMD2V","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"applyCenterForce(to:center:strength:)","modules":[{"name":"Graphs"}],"externalID":"s:6Graphs16applyCenterForce2to6center8strengthyAA15SimulationStateVz_s5SIMD2VySfGSftF","symbolKind":"func","roleHeading":"Function"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/graphs\/applycenterforce(to:center:strength:)"]}],"references":{"doc://Graphs/documentation/Graphs/applyCenterForce(to:center:strength:)":{"kind":"symbol","url":"\/documentation\/graphs\/applycenterforce(to:center:strength:)","abstract":[{"type":"text","text":"Applies a centering force that pulls the graph’s centroid toward a target point."}],"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/applyCenterForce(to:center:strength:)","title":"applyCenterForce(to:center:strength:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyCenterForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"center"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5SIMD2V","kind":"typeIdentifier","text":"SIMD2"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"},{"kind":"text","text":")"}],"type":"topic","role":"symbol"},"doc://Graphs/documentation/Graphs":{"role":"collection","title":"Graphs","url":"\/documentation\/graphs","identifier":"doc:\/\/Graphs\/documentation\/Graphs","kind":"symbol","type":"topic","abstract":[]},"doc://Graphs/documentation/Graphs/SimulationState":{"role":"symbol","title":"SimulationState","url":"\/documentation\/graphs\/simulationstate","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"SimulationState","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"The mutable state of a force-directed graph simulation."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"SimulationState"}]}}}