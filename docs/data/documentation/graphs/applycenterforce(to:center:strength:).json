{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyCenterForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":" "},{"kind":"internalParam","text":"state"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"center"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5SIMD2V","text":"SIMD2"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":"> = .zero, "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":" = 0.1)"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"state","content":[{"inlineContent":[{"text":"The simulation state to modify. Velocities are updated in place.","type":"text"}],"type":"paragraph"}]},{"name":"center","content":[{"inlineContent":[{"text":"The target center point. Defaults to the origin (0, 0).","type":"text"}],"type":"paragraph"}]},{"name":"strength","content":[{"inlineContent":[{"text":"How strongly to pull toward the center. Higher values cause","type":"text"},{"text":" ","type":"text"},{"text":"faster centering but may cause oscillation. Defaults to 0.1.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This force prevents the graph from drifting away from the visible area by"},{"type":"text","text":" "},{"type":"text","text":"gently nudging all nodes so their centroid moves toward the center."}]},{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The center force computes the centroid (average position) of all nodes and"},{"type":"text","text":" "},{"type":"text","text":"applies a velocity adjustment to move that centroid toward the target center."},{"type":"text","text":" "},{"type":"text","text":"This keeps the graph roughly centered in the view."}]},{"text":"Behavior","type":"heading","level":2,"anchor":"Behavior"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike other forces that operate on individual nodes, the center force operates"},{"type":"text","text":" "},{"type":"text","text":"on the graph as a whole. It doesn’t change the relative positions of nodes;"},{"type":"text","text":" "},{"type":"text","text":"it only translates the entire graph."}]},{"text":"Complexity","type":"heading","level":2,"anchor":"Complexity"},{"type":"paragraph","inlineContent":[{"type":"text","text":"O(N) where N is the number of nodes."}]},{"text":"Example","type":"heading","level":2,"anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["\/\/ Center at origin with default strength","applyCenterForce(to: &state)","","\/\/ Center at a specific point","applyCenterForce(to: &state, center: SIMD2(100, 100))","","\/\/ Stronger centering","applyCenterForce(to: &state, strength: 0.3)"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/graphs\/applycenterforce(to:center:strength:)"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Graphs\/documentation\/Graphs\/applyCenterForce(to:center:strength:)"},"abstract":[{"text":"Applies a centering force that pulls the graph’s centroid toward a target point.","type":"text"}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyCenterForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"center","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SIMD2","preciseIdentifier":"s:s5SIMD2V","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":")","kind":"text"}],"roleHeading":"Function","modules":[{"name":"Graphs"}],"title":"applyCenterForce(to:center:strength:)","role":"symbol","symbolKind":"func","externalID":"s:6Graphs16applyCenterForce2to6center8strengthyAA15SimulationStateVz_s5SIMD2VySfGSftF"},"references":{"doc://Graphs/documentation/Graphs/SimulationState":{"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","navigatorTitle":[{"kind":"identifier","text":"SimulationState"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SimulationState"}],"type":"topic","kind":"symbol","role":"symbol","title":"SimulationState","url":"\/documentation\/graphs\/simulationstate","abstract":[{"text":"The mutable state of a force-directed graph simulation.","type":"text"}]},"doc://Graphs/documentation/Graphs/applyCenterForce(to:center:strength:)":{"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"applyCenterForce","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"center","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SIMD2","preciseIdentifier":"s:s5SIMD2V","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/graphs\/applycenterforce(to:center:strength:)","title":"applyCenterForce(to:center:strength:)","role":"symbol","type":"topic","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/applyCenterForce(to:center:strength:)","abstract":[{"text":"Applies a centering force that pulls the graph’s centroid toward a target point.","type":"text"}]},"doc://Graphs/documentation/Graphs":{"title":"Graphs","url":"\/documentation\/graphs","identifier":"doc:\/\/Graphs\/documentation\/Graphs","abstract":[],"type":"topic","kind":"symbol","role":"collection"}}}