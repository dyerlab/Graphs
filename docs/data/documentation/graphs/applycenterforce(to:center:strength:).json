{"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"kind":"symbol","abstract":[{"type":"text","text":"Applies a centering force that pulls the graph’s centroid toward a target point."}],"variants":[{"paths":["\/documentation\/graphs\/applycenterforce(to:center:strength:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/Graphs\/documentation\/Graphs\/applyCenterForce(to:center:strength:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyCenterForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":" "},{"kind":"internalParam","text":"state"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"SimulationState","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState","preciseIdentifier":"s:6Graphs15SimulationStateV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"center"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5SIMD2V","text":"SIMD2","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sf","text":"Float","kind":"typeIdentifier"},{"text":"> = .zero, ","kind":"text"},{"text":"strength","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sf","text":"Float","kind":"typeIdentifier"},{"text":" = 0.1)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"state","content":[{"inlineContent":[{"text":"The simulation state to modify. Velocities are updated in place.","type":"text"}],"type":"paragraph"}]},{"name":"center","content":[{"inlineContent":[{"text":"The target center point. Defaults to the origin (0, 0).","type":"text"}],"type":"paragraph"}]},{"name":"strength","content":[{"inlineContent":[{"type":"text","text":"How strongly to pull toward the center. Higher values cause"},{"type":"text","text":" "},{"type":"text","text":"faster centering but may cause oscillation. Defaults to 0.1."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This force prevents the graph from drifting away from the visible area by"},{"type":"text","text":" "},{"type":"text","text":"gently nudging all nodes so their centroid moves toward the center."}]},{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"The center force computes the centroid (average position) of all nodes and","type":"text"},{"text":" ","type":"text"},{"text":"applies a velocity adjustment to move that centroid toward the target center.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This keeps the graph roughly centered in the view."}],"type":"paragraph"},{"text":"Behavior","type":"heading","level":2,"anchor":"Behavior"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike other forces that operate on individual nodes, the center force operates"},{"type":"text","text":" "},{"type":"text","text":"on the graph as a whole. It doesn’t change the relative positions of nodes;"},{"text":" ","type":"text"},{"text":"it only translates the entire graph.","type":"text"}]},{"level":2,"anchor":"Complexity","text":"Complexity","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"O(N) where N is the number of nodes."}]},{"level":2,"anchor":"Example","type":"heading","text":"Example"},{"type":"codeListing","syntax":"swift","code":["\/\/ Center at origin with default strength","applyCenterForce(to: &state)","","\/\/ Center at a specific point","applyCenterForce(to: &state, center: SIMD2(100, 100))","","\/\/ Stronger centering","applyCenterForce(to: &state, strength: 0.3)"]}]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"applyCenterForce"},{"kind":"text","text":"("},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:6Graphs15SimulationStateV","text":"SimulationState"},{"kind":"text","text":", "},{"kind":"externalParam","text":"center"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5SIMD2V","text":"SIMD2"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"strength"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":")"}],"roleHeading":"Function","role":"symbol","title":"applyCenterForce(to:center:strength:)","externalID":"s:6Graphs16applyCenterForce2to6center8strengthyAA15SimulationStateVz_s5SIMD2VySfGSftF","symbolKind":"func","modules":[{"name":"Graphs"}]},"references":{"doc://Graphs/documentation/Graphs/SimulationState":{"role":"symbol","type":"topic","kind":"symbol","navigatorTitle":[{"text":"SimulationState","kind":"identifier"}],"title":"SimulationState","url":"\/documentation\/graphs\/simulationstate","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimulationState","kind":"identifier"}],"abstract":[{"text":"The mutable state of a force-directed graph simulation.","type":"text"}],"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/SimulationState"},"doc://Graphs/documentation/Graphs/applyCenterForce(to:center:strength:)":{"type":"topic","role":"symbol","abstract":[{"text":"Applies a centering force that pulls the graph’s centroid toward a target point.","type":"text"}],"url":"\/documentation\/graphs\/applycenterforce(to:center:strength:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text",