{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Edge"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"inlineContent":[{"code":"Edge","type":"codeVoice"},{"text":" represents a directed connection between two nodes, identified by their","type":"text"},{"text":" ","type":"text"},{"text":"indices in the node array. Each edge has physics properties that control how","type":"text"},{"text":" ","type":"text"},{"text":"the force-directed simulation treats the connection.","type":"text"}],"type":"paragraph"},{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Edges connect nodes in a "},{"type":"reference","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/PopulationGraph","isActive":true},{"text":" and are grouped into ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/EdgeSet","type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"collections. Using integer indices rather than node references provides O(1)"},{"type":"text","text":" "},{"type":"text","text":"lookup performance, which is critical when switching between thousands of edge sets."}]},{"text":"Physics Model","anchor":"Physics-Model","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each edge acts as a spring in the force simulation:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/distance","isActive":true},{"text":" property is the spring’s rest length (target distance between nodes)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Graphs\/documentation\/Graphs\/Edge\/weight"},{"type":"text","text":" property controls the spring strength (how strongly nodes are pulled together)"}]}]}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"codeListing","syntax":"swift","code":["\/\/ Connect node 0 to node 1 with default spring properties","let edge1 = Edge(source: 0, target: 1)","","\/\/ Create a strong, short connection","let edge2 = Edge(source: 1, target: 2, weight: 2.0, distance: 20.0)","","\/\/ Create a weak, long connection","let edge3 = Edge(source: 0, target: 2, weight: 0.5, distance: 80.0)"]}]}],"abstract":[{"type":"text","text":"A connection between two nodes in a graph with spring-like physics properties."}],"variants":[{"paths":["\/documentation\/graphs\/edge"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"metadata":{"role":"symbol","title":"Edge","roleHeading":"Structure","externalID":"s:6Graphs4EdgeV","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Edge"}],"modules":[{"name":"Graphs"}],"navigatorTitle":[{"text":"Edge","kind":"identifier"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/Graphs\/documentation\/Graphs\/Edge","interfaceLanguage":"swift"},"relationshipsSections":[{"identifiers":["doc:\/\/Graphs\/SQ","doc:\/\/Graphs\/SH","doc:\/\/Graphs\/s8SendableP","doc:\/\/Graphs\/s16SendableMetatypeP"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"hierarchy":{"paths":[["doc:\/\/Graphs\/documentation\/Graphs"]]},"topicSections":[{"title":"Creating Edges","identifiers":["doc:\/\/Graphs\/documentation\/Graphs\/Edge\/init(source:target:weight:distance:)"],"anchor":"Creating-Edges"},{"title":"Node References","identifiers":["doc:\/\/Graphs\/documentation\/Graphs\/Edge\/source","doc:\/\/Graphs\/documentation\/Graphs\/Edge\/target"],"anchor":"Node-References"},{"ide